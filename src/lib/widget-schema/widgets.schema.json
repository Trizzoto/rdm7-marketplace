        { "name": "needle_angle_offset","label": "Needle Angle Offset","type": "stepper", "default": 0, "category": "appearance", "min": -180, "max": 180, "enabled_by": "needle_image_name" },
        { "name": "needle_width",      "label": "Needle Width",  "type": "stepper", "default": 4, "category": "appearance", "min": 1, "max": 20 },
