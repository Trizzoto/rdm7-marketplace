        { "name": "warning_low_color",           "label": "Color",            "type": "color",    "default": "#0000FF", "category": "alerts", "group": "low", "enabled_by": "warning_low_enabled" },
        { "name": "warning_low_apply_label",     "label": "Label",            "type": "checkbox", "default": true,  "category": "alerts", "group": "low", "enabled_by": "warning_low_enabled", "inline": "warning_low_apply" },
        { "name": "warning_low_apply_value",     "label": "Value",            "type": "checkbox", "default": true,  "category": "alerts", "group": "low", "enabled_by": "warning_low_enabled", "inline": "warning_low_apply" },
        { "name": "warning_low_apply_panel",     "label": "Panel",            "type": "checkbox", "default": false, "category": "alerts", "group": "low", "enabled_by": "warning_low_enabled", "inline": "warning_low_apply" },
        { "name": "label_font",                  "label": "Label Font",       "type": "font",     "default": "",   "category": "appearance" },
        { "name": "value_font",                  "label": "Value Font",       "type": "font",     "default": "",   "category": "appearance" },
        { "name": "border_radius",               "label": "Border Radius",    "type": "stepper",  "default": 7,    "category": "appearance", "min": 0, "max": 100 },
        { "name": "border_width",                "label": "Border Width",     "type": "stepper",  "default": 3,    "category": "appearance", "min": 0, "max": 20 },
        { "name": "border_color",                "label": "Border Color",     "type": "color",    "default": "#2E2F2E", "category": "appearance", "night_overridable": true },
        { "name": "bg_color",                    "label": "Background",       "type": "color",    "default": "#000000", "category": "appearance", "night_overridable": true },
        { "name": "bg_opa",                      "label": "BG Opacity",       "type": "stepper",  "default": 255,  "category": "appearance", "min": 0, "max": 255 },
        { "name": "label_color",                 "label": "Label Color",      "type": "color",    "default": "#FFFFFF", "category": "appearance", "night_overridable": true },
        { "name": "value_color",                 "label": "Value Color",      "type": "color",    "default": "#FFFFFF", "category": "appearance", "night_overridable": true },
        { "name": "label_y_offset",              "label": "Label Y Offset",   "type": "stepper",  "default": -28,  "category": "appearance", "min": -100, "max": 100 },
        { "name": "value_y_offset",              "label": "Value Y Offset",   "type": "stepper",  "default": 9,    "category": "appearance", "min": -100, "max": 100 },
