        { "name": "label_font",       "label": "Label Font",  "type": "font",     "default": "",   "category": "appearance" },
        { "name": "value_font",       "label": "Value Font",  "type": "font",     "default": "",   "category": "appearance" },
        { "name": "bar_bg_color",     "label": "Track Color", "type": "color",    "default": "#2E2F2E", "category": "appearance", "night_overridable": true },
        { "name": "bar_radius",       "label": "Bar Radius",  "type": "stepper",  "default": 5,    "category": "appearance", "min": 0, "max": 50 },
        { "name": "bar_border_width", "label": "Border Width", "type": "stepper", "default": 2,    "category": "appearance", "min": 0, "max": 20 },
        { "name": "bar_border_color", "label": "Border Color", "type": "color",   "default": "#2E2F2E", "category": "appearance", "night_overridable": true },
        { "name": "indicator_radius", "label": "Fill Radius", "type": "stepper",  "default": 5,    "category": "appearance", "min": 0, "max": 50 },
