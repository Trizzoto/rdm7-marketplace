        { "name": "value_color",      "label": "Value Color", "type": "color",    "default": "#FFFFFF", "category": "appearance", "night_overridable": true },
        { "name": "bar_image",        "label": "Track Image", "type": "image_picker", "default": "", "category": "appearance", "night_overridable": true },
