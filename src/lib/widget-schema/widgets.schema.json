        { "name": "needle_rear_length","label": "Needle Rear Length","type": "stepper", "default": 0, "category": "appearance", "min": 0, "max": 100 },
        { "name": "needle_tip_style",  "label": "Needle Tip Style","type": "select", "default": 0, "category": "appearance",
          "options": [
            { "value": 0, "label": "Flat" },
            { "value": 1, "label": "Rounded" },
            { "value": 2, "label": "Lance" },
            { "value": 3, "label": "Dagger" },
            { "value": 4, "label": "Spade" },
            { "value": 5, "label": "Diamond" }
          ] },
        { "name": "needle_tip_base_w", "label": "Tip Base Width", "type": "stepper-auto", "default": 0, "category": "appearance", "min": 0, "max": 30,
          "_doc": "Tip-tuning knobs. Stored value 0 = \"use the built-in\ndefault for the current style\". `autoFn` returns the\nresolved default the firmware would pick - mirrors the\nsame defaults used in widget_meter.c's DRAW_PART hook\nso the inspector can show the effective number even\nwhen the user hasn't entered an explicit override.",
          "_raw_extra": {
            "autoFn": "function(cfg) {\n                          var nw = cfg.needle_width || 4;\n                          switch (cfg.needle_tip_style) {\n                              case 2: return (nw >> 1) + 1;  // Lance\n                              case 3: return (nw >> 1) + 2;  // Dagger\n                              case 4: return (nw >> 1) + 2;  // Spade\n                              case 5: return (nw >> 1) + 3;  // Diamond\n                              default: return 0;\n                          }\n                      }"
          } },
        { "name": "needle_tip_point_w","label": "Tip Point Width","type": "stepper-auto", "default": 0, "category": "appearance", "min": 0, "max": 20,
          "_raw_extra": {
            "autoFn": "function(cfg) {\n                          return cfg.needle_tip_style === 4 ? 1 : 0;  // only Spade has a default cap\n                      }"
          } },
        { "name": "needle_tip_taper", "label": "Tip Taper %",   "type": "stepper-auto", "default": 0, "category": "appearance", "min": 0, "max": 100,
          "_raw_extra": {
            "autoFn": "function(cfg) {\n                          switch (cfg.needle_tip_style) {\n                              case 2: return 90;   // Lance: shaft ends here\n                              case 3: return 100;  // Dagger: tapers across full length\n                              case 4: return 97;   // Spade: cap position\n                              case 5: return 50;   // Diamond: widest point\n                              default: return 0;\n                          }\n                      }"
          } },
        { "name": "needle_ball_size", "label": "Needle Ball Size", "type": "stepper", "default": 10, "category": "appearance", "min": 0, "max": 40 },
        { "name": "needle_ball_color","label": "Needle Ball Color","type": "color", "default": "#FFFFFF", "category": "appearance", "night_overridable": true }
