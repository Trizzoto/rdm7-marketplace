        { "name": "limiter_effect", "label": "Limiter Effect","type": "select", "default": 0, "category": "appearance",
          "options": [
            { "value": 0, "label": "None" },
            { "value": 1, "label": "Bar Flash" },
            { "value": 2, "label": "Bar Solid" }
          ] },
        { "name": "limiter_value",  "label": "Limiter RPM",   "type": "number", "default": 7000, "category": "data" },
        { "name": "limiter_color",  "label": "Limiter Color", "type": "color",  "default": "#FF0000", "category": "appearance", "night_overridable": true },
        { "name": "flash_speed",    "label": "Flash Speed (ms)", "type": "stepper", "default": 200, "category": "appearance", "min": 50, "max": 1000, "step": 50 }
      ]
    },
